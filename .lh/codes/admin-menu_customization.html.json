            "date": 1772564874527,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Menu Customization - Admin Dashboard</title>\r\n\r\n    <!-- Bootstrap 5 CSS -->\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <!-- Font Awesome -->\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <!-- Animate.css -->\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css\">\r\n\r\n    <!-- Custom CSS -->\r\n    <link rel=\"stylesheet\" href=\"style.css\">\r\n    <link rel=\"stylesheet\" href=\"admin.css\">\r\n    \r\n    <style>\r\n        /* Tab Styling */\r\n        .category-tabs {\r\n            background: linear-gradient(135deg, #800000, #660000);\r\n            border-radius: 15px 15px 0 0;\r\n            padding: 15px 20px 0;\r\n        }\r\n        \r\n        .category-tabs .nav-link {\r\n            color: rgba(255, 255, 255, 0.8);\r\n            border: none;\r\n            border-radius: 12px 12px 0 0;\r\n            padding: 15px 30px;\r\n            font-weight: 600;\r\n            font-size: 1rem;\r\n            transition: all 0.3s ease;\r\n            background: rgba(255, 255, 255, 0.1);\r\n            margin-right: 5px;\r\n        }\r\n        \r\n        .category-tabs .nav-link:hover {\r\n            color: white;\r\n            background: rgba(255, 255, 255, 0.2);\r\n            transform: translateY(-2px);\r\n        }\r\n        \r\n        .category-tabs .nav-link.active {\r\n            color: #800000;\r\n            background: white;\r\n            font-weight: 700;\r\n            box-shadow: 0 -5px 15px rgba(0, 0, 0, 0.1);\r\n        }\r\n        \r\n        .tab-content-wrapper {\r\n            background: white;\r\n            border-radius: 0 0 15px 15px;\r\n            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);\r\n        }\r\n        \r\n        .tab-pane {\r\n            padding: 25px;\r\n        }\r\n        \r\n        /* Table Styling */\r\n        .category-table {\r\n            border-radius: 10px;\r\n            overflow: hidden;\r\n        }\r\n        \r\n        .category-table thead {\r\n            background: #dc3545;\r\n            color: white !important;\r\n        }\r\n        \r\n        .category-table thead th {\r\n            border: none;\r\n            padding: 15px;\r\n            font-weight: 600;\r\n            color: white !important;\r\n        }\r\n        \r\n        .category-table tbody tr {\r\n            transition: all 0.2s ease;\r\n        }\r\n        \r\n        .category-table tbody tr:hover {\r\n            background-color: rgba(128, 0, 0, 0.05);\r\n        }\r\n        \r\n        /* Action Buttons */\r\n        .btn-action {\r\n            width: 35px;\r\n            height: 35px;\r\n            padding: 0;\r\n            display: inline-flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            border-radius: 8px;\r\n            transition: all 0.2s ease;\r\n        }\r\n        \r\n        .btn-action:hover {\r\n            transform: scale(1.1);\r\n        }\r\n        \r\n        /* Add Button */\r\n        .btn-add-category {\r\n            background: linear-gradient(135deg, #800000, #660000);\r\n            border: none;\r\n            color: white;\r\n            padding: 12px 25px;\r\n            border-radius: 10px;\r\n            font-weight: 600;\r\n            transition: all 0.3s ease;\r\n        }\r\n        \r\n        .btn-add-category:hover {\r\n            transform: translateY(-2px);\r\n            box-shadow: 0 5px 20px rgba(128, 0, 0, 0.3);\r\n            color: white;\r\n        }\r\n        \r\n        /* Status Badge */\r\n        .status-badge {\r\n            padding: 5px 12px;\r\n            border-radius: 20px;\r\n            font-size: 0.85rem;\r\n            font-weight: 500;\r\n        }\r\n        \r\n        .status-active {\r\n            background: rgba(40, 167, 69, 0.15);\r\n            color: #28a745;\r\n        }\r\n        \r\n        .status-inactive {\r\n            background: rgba(220, 53, 69, 0.15);\r\n            color: #dc3545;\r\n        }\r\n        \r\n        /* Search Box */\r\n        .search-box {\r\n            position: relative;\r\n        }\r\n        \r\n        .search-box input {\r\n            padding-left: 45px;\r\n            border-radius: 10px;\r\n            border: 2px solid #e1e5e9;\r\n            transition: all 0.3s ease;\r\n        }\r\n        \r\n        .search-box input:focus {\r\n            border-color: #800000;\r\n            box-shadow: 0 0 0 3px rgba(128, 0, 0, 0.1);\r\n        }\r\n        \r\n        .search-box i {\r\n            position: absolute;\r\n            left: 15px;\r\n            top: 50%;\r\n            transform: translateY(-50%);\r\n            color: #999;\r\n        }\r\n        \r\n        /* Empty State */\r\n        .empty-state {\r\n            text-align: center;\r\n            padding: 50px 20px;\r\n            color: #999;\r\n        }\r\n        \r\n        .empty-state i {\r\n            font-size: 4rem;\r\n            margin-bottom: 20px;\r\n            opacity: 0.5;\r\n        }\r\n    </style>\r\n    \r\n    <script>\r\n        // Immediate Sidebar State Initialization\r\n        (function () {\r\n            const html = document.documentElement;\r\n            html.classList.add('initializing');\r\n\r\n            const sidebarState = localStorage.getItem('sidebarActive');\r\n            if (sidebarState === 'true' && window.innerWidth >= 992) {\r\n                html.classList.add('sidebar-active');\r\n            }\r\n\r\n            // Auth Guard (Admin/Owner version)\r\n            try {\r\n                const role = localStorage.getItem('loggedInRole');\r\n                if (role !== 'admin' && role !== 'owner') {\r\n                    window.location.href = 'index.html';\r\n                }\r\n            } catch (e) {\r\n                window.location.href = 'index.html';\r\n            }\r\n        })();\r\n    </script>\r\n</head>\r\n\r\n<body>\r\n    <!-- Navigation Bar -->\r\n    <nav class=\"navbar navbar-expand-lg navbar-dark bg-black fixed-top shadow\">\r\n        <div class=\"container-fluid\">\r\n            <button class=\"sidebar-toggle mt-1 me-2\" id=\"sidebarToggle\">\r\n                <i class=\"fas fa-bars\"></i>\r\n            </button>\r\n\r\n            <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#headerNav\">\r\n                <span class=\"fas fa-ellipsis-v\"></span>\r\n            </button>\r\n            <div class=\"collapse navbar-collapse\" id=\"headerNav\">\r\n                <ul class=\"navbar-nav ms-auto\">\r\n                    <li class=\"nav-item dropdown\">\r\n                        <a class=\"nav-link dropdown-toggle\" href=\"#\" role=\"button\" data-bs-toggle=\"dropdown\">\r\n                            <i class=\"fas fa-user-shield me-1\"></i>Administrator\r\n                        </a>\r\n                        <ul class=\"dropdown-menu dropdown-menu-end shadow border-0 animate__animated animate__fadeIn\">\r\n                            <li><a class=\"dropdown-item\" href=\"admin-system-settings.html\"><i\r\n                                        class=\"fas fa-cog me-2 text-danger\"></i>Settings</a></li>\r\n                            <li><a class=\"dropdown-item\" href=\"admin-activity-log.html\"><i\r\n                                        class=\"fas fa-history me-2 text-danger\"></i>Activity Log</a></li>\r\n                            <li>\r\n                                <hr class=\"dropdown-divider\">\r\n                            </li>\r\n                            <li><a class=\"dropdown-item text-danger\" href=\"#\" id=\"logoutBtn\"><i\r\n                                        class=\"fas fa-sign-out-alt me-2\"></i>Logout</a></li>\r\n                        </ul>\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n        </div>\r\n    </nav>\r\n\r\n    <div class=\"dashboard-layout\">\r\n        <!-- Sidebar Navigation -->\r\n        <aside class=\"sidebar\" id=\"sidebar\">\r\n            <div class=\"sidebar-branding\">\r\n                <button class=\"sidebar-toggle in-sidebar\" id=\"sidebarToggleInternal\">\r\n                    <i class=\"fas fa-bars\"></i>\r\n                </button>\r\n                <a href=\"admin-dashboard.html\" class=\"sidebar-brand-group\">\r\n                    <img src=\"resources/ethans logo.jpg\" alt=\"Logo\">\r\n                    <span class=\"pos-label\">POS</span>\r\n                </a>\r\n            </div>\r\n            <div class=\"sidebar-nav\">\r\n                <div class=\"sidebar-section-title\">Navigation</div>\r\n                <a href=\"admin-dashboard.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-tachometer-alt\"></i>Dashboard\r\n                </a>\r\n                <a href=\"admin-menu-control.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-utensils\"></i>Menu Control\r\n                </a>\r\n                <a href=\"admin-recipe-control.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-book\"></i>Recipe Control\r\n                </a>\r\n                <a href=\"admin-ingredients-masterlist.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-boxes\"></i>Ingredients\r\n                </a>\r\n                <a href=\"admin-menu_customization.html\" class=\"sidebar-link active\">\r\n                    <i class=\"fas fa-palette\"></i>Menu Customization\r\n                </a>\r\n                <a href=\"admin-user-management.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-users\"></i>Users\r\n                </a>\r\n                <a href=\"admin-requests.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-inbox\"></i>Requests\r\n                </a>\r\n\r\n                <div class=\"sidebar-divider\"></div>\r\n                <div class=\"sidebar-section-title\">Reports & Data</div>\r\n                <a href=\"admin-reports.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-chart-bar\"></i>Owner Reports\r\n                </a>\r\n                <a href=\"admin-backup.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-database\"></i>Backup & Restore\r\n                </a>\r\n\r\n                <div class=\"sidebar-divider\"></div>\r\n                <div class=\"sidebar-section-title\">System</div>\r\n                <a href=\"admin-system-settings.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-cog\"></i>System Settings\r\n                </a>\r\n                <a href=\"admin-activity-log.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-history\"></i>Full Activity Log\r\n                </a>\r\n            </div>\r\n        </aside>\r\n\r\n        <!-- Main Content Area -->\r\n        <main class=\"main-content\">\r\n            <div class=\"page-content\">\r\n                <!-- Page Header -->\r\n                <div class=\"d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom\">\r\n                    <h1 class=\"h2\"><i class=\"fas fa-palette me-2 text-danger\"></i>Menu Customization</h1>\r\n                </div>\r\n\r\n                <!-- Tabs Container -->\r\n                <div class=\"card shadow-sm border-0\">\r\n                    <!-- Tab Navigation -->\r\n                    <ul class=\"nav nav-tabs category-tabs\" id=\"categoryTabs\" role=\"tablist\">\r\n                        <li class=\"nav-item\" role=\"presentation\">\r\n                            <button class=\"nav-link active\" id=\"menu-categories-tab\" data-bs-toggle=\"tab\"\r\n                                data-bs-target=\"#menu-categories\" type=\"button\" role=\"tab\">\r\n                                <i class=\"fas fa-utensils me-2\"></i>Menu Categories\r\n                            </button>\r\n                        </li>\r\n                        <li class=\"nav-item\" role=\"presentation\">\r\n                            <button class=\"nav-link\" id=\"ingredient-categories-tab\" data-bs-toggle=\"tab\"\r\n                                data-bs-target=\"#ingredient-categories\" type=\"button\" role=\"tab\">\r\n                                <i class=\"fas fa-boxes me-2\"></i>Ingredient Categories\r\n                            </button>\r\n                        </li>\r\n                    </ul>\r\n\r\n                    <!-- Tab Content -->\r\n                    <div class=\"tab-content tab-content-wrapper\" id=\"categoryTabsContent\">\r\n                        \r\n                        <!-- Menu Categories Tab -->\r\n                        <div class=\"tab-pane fade show active\" id=\"menu-categories\" role=\"tabpanel\">\r\n                            <!-- Toolbar -->\r\n                            <div class=\"d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3\">\r\n                                <div class=\"search-box\" style=\"min-width: 300px;\">\r\n                                    <i class=\"fas fa-search\"></i>\r\n                                    <input type=\"text\" class=\"form-control\" id=\"searchMenuCategories\" \r\n                                        placeholder=\"Search menu categories...\">\r\n                                </div>\r\n                                <button class=\"btn btn-add-category\" id=\"addMenuCategoryBtn\">\r\n                                    <i class=\"fas fa-plus me-2\"></i>Add Category\r\n                                </button>\r\n                            </div>\r\n\r\n                            <!-- Menu Categories Table -->\r\n                            <div class=\"table-responsive\">\r\n                                <table class=\"table category-table align-middle\" id=\"menuCategoriesTable\">\r\n                                    <thead>\r\n                                        <tr>\r\n                                            <th style=\"width: 60px;\">#</th>\r\n                                            <th>Category Name</th>\r\n                                            <th>Description</th>\r\n                                            <th style=\"width: 100px;\">Items</th>\r\n                                            <th style=\"width: 120px;\">Actions</th>\r\n                                        </tr>\r\n                                    </thead>\r\n                                    <tbody id=\"menuCategoriesBody\">\r\n                                        <!-- Data loaded here -->\r\n                                    </tbody>\r\n                                </table>\r\n                            </div>\r\n                        </div>\r\n\r\n                        <!-- Ingredient Categories Tab -->\r\n                        <div class=\"tab-pane fade\" id=\"ingredient-categories\" role=\"tabpanel\">\r\n                            <!-- Toolbar -->\r\n                            <div class=\"d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3\">\r\n                                <div class=\"search-box\" style=\"min-width: 300px;\">\r\n                                    <i class=\"fas fa-search\"></i>\r\n                                    <input type=\"text\" class=\"form-control\" id=\"searchIngredientCategories\" \r\n                                        placeholder=\"Search ingredient categories...\">\r\n                                </div>\r\n                                <button class=\"btn btn-add-category\" id=\"addIngredientCategoryBtn\">\r\n                                    <i class=\"fas fa-plus me-2\"></i>Add Category\r\n                                </button>\r\n                            </div>\r\n\r\n                            <!-- Ingredient Categories Table -->\r\n                            <div class=\"table-responsive\">\r\n                                <table class=\"table category-table align-middle\" id=\"ingredientCategoriesTable\">\r\n                                    <thead>\r\n                                        <tr>\r\n                                            <th style=\"width: 60px;\">#</th>\r\n                                            <th>Category Name</th>\r\n                                            <th style=\"width: 100px;\">Items</th>\r\n                                            <th style=\"width: 120px;\">Actions</th>\r\n                                        </tr>\r\n                                    </thead>\r\n                                    <tbody id=\"ingredientCategoriesBody\">\r\n                                        <!-- Data loaded here -->\r\n                                    </tbody>\r\n                                </table>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </main>\r\n    </div>\r\n\r\n    <!-- Add/Edit Menu Category Modal -->\r\n    <div class=\"modal fade\" id=\"menuCategoryModal\" tabindex=\"-1\">\r\n        <div class=\"modal-dialog modal-dialog-centered\">\r\n            <div class=\"modal-content\">\r\n                <div class=\"modal-header bg-black text-white\">\r\n                    <h5 class=\"modal-title\" id=\"menuCategoryModalTitle\">\r\n                        <i class=\"fas fa-utensils me-2\"></i>Add Menu Category\r\n                    </h5>\r\n                    <button type=\"button\" class=\"btn-close btn-close-white\" data-bs-dismiss=\"modal\"></button>\r\n                </div>\r\n                <div class=\"modal-body\">\r\n                    <form id=\"menuCategoryForm\">\r\n                        <input type=\"hidden\" id=\"menuCategoryId\">\r\n                        <div class=\"mb-3\">\r\n                            <label class=\"form-label fw-bold\">Category Name <span class=\"text-danger\">*</span></label>\r\n                            <input type=\"text\" class=\"form-control\" id=\"menuCategoryName\" required \r\n                                placeholder=\"e.g., Main Dishes, Beverages\">\r\n                        </div>\r\n                        <div class=\"mb-3\">\r\n                            <label class=\"form-label fw-bold\">Description</label>\r\n                            <textarea class=\"form-control\" id=\"menuCategoryDescription\" rows=\"3\" \r\n                                placeholder=\"Brief description of this category...\"></textarea>\r\n                        </div>\r\n                    </form>\r\n                </div>\r\n                <div class=\"modal-footer\">\r\n                    <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Cancel</button>\r\n                    <button type=\"button\" class=\"btn btn-danger\" id=\"saveMenuCategoryBtn\">\r\n                        <i class=\"fas fa-save me-1\"></i>Save Category\r\n                    </button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Add/Edit Ingredient Category Modal -->\r\n    <div class=\"modal fade\" id=\"ingredientCategoryModal\" tabindex=\"-1\">\r\n        <div class=\"modal-dialog modal-dialog-centered\">\r\n            <div class=\"modal-content\">\r\n                <div class=\"modal-header bg-black text-white\">\r\n                    <h5 class=\"modal-title\" id=\"ingredientCategoryModalTitle\">\r\n                        <i class=\"fas fa-boxes me-2\"></i>Add Ingredient Category\r\n                    </h5>\r\n                    <button type=\"button\" class=\"btn-close btn-close-white\" data-bs-dismiss=\"modal\"></button>\r\n                </div>\r\n                <div class=\"modal-body\">\r\n                    <form id=\"ingredientCategoryForm\">\r\n                        <input type=\"hidden\" id=\"ingredientCategoryId\">\r\n                        <div class=\"mb-3\">\r\n                            <label class=\"form-label fw-bold\">Category Name <span class=\"text-danger\">*</span></label>\r\n                            <input type=\"text\" class=\"form-control\" id=\"ingredientCategoryName\" required \r\n                                placeholder=\"e.g., Dairy, Vegetables, Spices\">\r\n                        </div>\r\n                    </form>\r\n                </div>\r\n                <div class=\"modal-footer\">\r\n                    <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Cancel</button>\r\n                    <button type=\"button\" class=\"btn btn-danger\" id=\"saveIngredientCategoryBtn\">\r\n                        <i class=\"fas fa-save me-1\"></i>Save Category\r\n                    </button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Delete Confirmation Modal -->\r\n    <div class=\"modal fade\" id=\"deleteCategoryModal\" tabindex=\"-1\">\r\n        <div class=\"modal-dialog modal-dialog-centered modal-sm\">\r\n            <div class=\"modal-content\">\r\n                <div class=\"modal-header bg-danger text-white\">\r\n                    <h5 class=\"modal-title\"><i class=\"fas fa-trash me-2\"></i>Delete Category</h5>\r\n                    <button type=\"button\" class=\"btn-close btn-close-white\" data-bs-dismiss=\"modal\"></button>\r\n                </div>\r\n                <div class=\"modal-body text-center\">\r\n                    <i class=\"fas fa-exclamation-triangle text-warning fa-3x mb-3\"></i>\r\n                    <p>Are you sure you want to delete <strong id=\"deleteCategoryName\"></strong>?</p>\r\n                    <p class=\"text-muted small\">This action cannot be undone.</p>\r\n                    <input type=\"hidden\" id=\"deleteCategoryId\">\r\n                    <input type=\"hidden\" id=\"deleteCategoryType\">\r\n                </div>\r\n                <div class=\"modal-footer justify-content-center\">\r\n                    <button type=\"button\" class=\"btn btn-secondary\" data-bs-dismiss=\"modal\">Cancel</button>\r\n                    <button type=\"button\" class=\"btn btn-danger\" id=\"confirmDeleteBtn\">\r\n                        <i class=\"fas fa-trash me-1\"></i>Delete\r\n                    </button>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Bootstrap 5 JS -->\r\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js\"></script>\r\n    <script src=\"https://code.jquery.com/jquery-3.6.4.min.js\"></script>\r\n    <script src=\"https://cdn.jsdelivr.net/npm/sweetalert2@11\"></script>\r\n\r\n    <!-- Custom JS -->\r\n    <script src=\"main.js\"></script>\r\n    <script src=\"admin.js\"></script>\r\n\r\n    <script>\r\n        // Category Management API\r\n        const CATEGORY_API = 'php/categories.php';\r\n\r\n        // Store data\r\n        let menuCategories = [];\r\n        let ingredientCategories = [];\r\n\r\n        // Modal instances\r\n        let menuCategoryModal, ingredientCategoryModal, deleteCategoryModal;\r\n\r\n        document.addEventListener('DOMContentLoaded', function() {\r\n            // Initialize modals\r\n            menuCategoryModal = new bootstrap.Modal(document.getElementById('menuCategoryModal'));\r\n            ingredientCategoryModal = new bootstrap.Modal(document.getElementById('ingredientCategoryModal'));\r\n            deleteCategoryModal = new bootstrap.Modal(document.getElementById('deleteCategoryModal'));\r\n\r\n            // Load data\r\n            loadMenuCategories();\r\n            loadIngredientCategories();\r\n\r\n            // Event Listeners\r\n            document.getElementById('addMenuCategoryBtn').addEventListener('click', () => openMenuCategoryModal());\r\n            document.getElementById('addIngredientCategoryBtn').addEventListener('click', () => openIngredientCategoryModal());\r\n            document.getElementById('saveMenuCategoryBtn').addEventListener('click', saveMenuCategory);\r\n            document.getElementById('saveIngredientCategoryBtn').addEventListener('click', saveIngredientCategory);\r\n            document.getElementById('confirmDeleteBtn').addEventListener('click', confirmDelete);\r\n\r\n            // Search functionality\r\n            document.getElementById('searchMenuCategories').addEventListener('input', function() {\r\n                renderMenuCategories(this.value);\r\n            });\r\n            document.getElementById('searchIngredientCategories').addEventListener('input', function() {\r\n                renderIngredientCategories(this.value);\r\n            });\r\n        });\r\n\r\n        // =============== MENU CATEGORIES ===============\r\n\r\n        async function loadMenuCategories() {\r\n            const tbody = document.getElementById('menuCategoriesBody');\r\n            tbody.innerHTML = '<tr><td colspan=\"5\" class=\"text-center py-4\"><div class=\"spinner-border text-danger\" role=\"status\"></div><p class=\"mt-2 text-muted\">Loading categories...</p></td></tr>';\r\n\r\n            try {\r\n                const response = await fetch(`${CATEGORY_API}?action=list&type=menu`);\r\n                const data = await response.json();\r\n\r\n                if (data.success) {\r\n                    menuCategories = data.categories || [];\r\n                    renderMenuCategories();\r\n                } else {\r\n                    throw new Error(data.error || 'Failed to load');\r\n                }\r\n            } catch (error) {\r\n                console.error('Error loading menu categories:', error);\r\n                tbody.innerHTML = `<tr><td colspan=\"5\" class=\"text-center py-4 text-danger\"><i class=\"fas fa-exclamation-circle me-2\"></i>Failed to load categories</td></tr>`;\r\n            }\r\n        }\r\n\r\n        function renderMenuCategories(searchTerm = '') {\r\n            const tbody = document.getElementById('menuCategoriesBody');\r\n            let filtered = menuCategories;\r\n\r\n            if (searchTerm) {\r\n                const term = searchTerm.toLowerCase();\r\n                filtered = menuCategories.filter(cat => \r\n                    cat.name.toLowerCase().includes(term) || \r\n                    (cat.description && cat.description.toLowerCase().includes(term))\r\n                );\r\n            }\r\n\r\n            if (filtered.length === 0) {\r\n                tbody.innerHTML = `\r\n                    <tr>\r\n                        <td colspan=\"5\">\r\n                            <div class=\"empty-state\">\r\n                                <i class=\"fas fa-utensils\"></i>\r\n                                <h5>No Menu Categories Found</h5>\r\n                                <p class=\"text-muted\">${searchTerm ? 'Try a different search term' : 'Click \"Add Category\" to create one'}</p>\r\n                            </div>\r\n                        </td>\r\n                    </tr>`;\r\n                return;\r\n            }\r\n\r\n            tbody.innerHTML = filtered.map((cat, index) => `\r\n                <tr>\r\n                    <td class=\"text-muted\">${index + 1}</td>\r\n                    <td><strong>${escapeHtml(cat.name)}</strong></td>\r\n                    <td class=\"text-muted\">${escapeHtml(cat.description || '-')}</td>\r\n                    <td><span class=\"badge bg-secondary\">${cat.item_count || 0}</span></td>\r\n                    <td>\r\n                        <button class=\"btn btn-action btn-outline-primary me-1\" onclick=\"editMenuCategory(${cat.id})\" title=\"Edit\">\r\n                            <i class=\"fas fa-edit\"></i>\r\n                        </button>\r\n                        <button class=\"btn btn-action btn-outline-danger\" onclick=\"deleteCategory(${cat.id}, 'menu', '${escapeHtml(cat.name)}')\" title=\"Delete\">\r\n                            <i class=\"fas fa-trash\"></i>\r\n                        </button>\r\n                    </td>\r\n                </tr>\r\n            `).join('');\r\n        }\r\n\r\n        function openMenuCategoryModal(category = null) {\r\n            document.getElementById('menuCategoryId').value = category ? category.id : '';\r\n            document.getElementById('menuCategoryName').value = category ? category.name : '';\r\n            document.getElementById('menuCategoryDescription').value = category ? category.description || '' : '';\r\n            document.getElementById('menuCategoryModalTitle').innerHTML = category \r\n                ? '<i class=\"fas fa-edit me-2\"></i>Edit Menu Category' \r\n                : '<i class=\"fas fa-plus me-2\"></i>Add Menu Category';\r\n            menuCategoryModal.show();\r\n        }\r\n\r\n        function editMenuCategory(id) {\r\n            const category = menuCategories.find(c => c.id === id);\r\n            if (category) openMenuCategoryModal(category);\r\n        }\r\n\r\n        async function saveMenuCategory() {\r\n            const id = document.getElementById('menuCategoryId').value;\r\n            const name = document.getElementById('menuCategoryName').value.trim();\r\n            const description = document.getElementById('menuCategoryDescription').value.trim();\r\n\r\n            if (!name) {\r\n                showModalNotification('Please enter a category name', 'warning');\r\n                return;\r\n            }\r\n\r\n            const btn = document.getElementById('saveMenuCategoryBtn');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<i class=\"fas fa-spinner fa-spin me-1\"></i>Saving...';\r\n\r\n            try {\r\n                const response = await fetch(`${CATEGORY_API}?action=${id ? 'update' : 'create'}`, {\r\n                    method: 'POST',\r\n                    headers: { 'Content-Type': 'application/json' },\r\n                    body: JSON.stringify({\r\n                        id: id || null,\r\n                        type: 'menu',\r\n                        name,\r\n                        description\r\n                    })\r\n                });\r\n\r\n                const data = await response.json();\r\n\r\n                if (data.success) {\r\n                    showModalNotification(id ? 'Category updated!' : 'Category created!', 'success');\r\n                    menuCategoryModal.hide();\r\n                    loadMenuCategories();\r\n                } else {\r\n                    throw new Error(data.error || 'Failed to save');\r\n                }\r\n            } catch (error) {\r\n                console.error('Error saving menu category:', error);\r\n                showModalNotification('Failed to save category', 'error');\r\n            } finally {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '<i class=\"fas fa-save me-1\"></i>Save Category';\r\n            }\r\n        }\r\n\r\n        // =============== INGREDIENT CATEGORIES ===============\r\n\r\n        async function loadIngredientCategories() {\r\n            const tbody = document.getElementById('ingredientCategoriesBody');\r\n            tbody.innerHTML = '<tr><td colspan=\"4\" class=\"text-center py-4\"><div class=\"spinner-border text-danger\" role=\"status\"></div><p class=\"mt-2 text-muted\">Loading categories...</p></td></tr>';\r\n\r\n            try {\r\n                const response = await fetch(`${CATEGORY_API}?action=list&type=ingredient`);\r\n                const data = await response.json();\r\n\r\n                if (data.success) {\r\n                    ingredientCategories = data.categories || [];\r\n                    renderIngredientCategories();\r\n                } else {\r\n                    throw new Error(data.error || 'Failed to load');\r\n                }\r\n            } catch (error) {\r\n                console.error('Error loading ingredient categories:', error);\r\n                tbody.innerHTML = `<tr><td colspan=\"4\" class=\"text-center py-4 text-danger\"><i class=\"fas fa-exclamation-circle me-2\"></i>Failed to load categories</td></tr>`;\r\n            }\r\n        }\r\n\r\n        function renderIngredientCategories(searchTerm = '') {\r\n            const tbody = document.getElementById('ingredientCategoriesBody');\r\n            let filtered = ingredientCategories;\r\n\r\n            if (searchTerm) {\r\n                const term = searchTerm.toLowerCase();\r\n                filtered = ingredientCategories.filter(cat => \r\n                    cat.name.toLowerCase().includes(term)\r\n                );\r\n            }\r\n\r\n            if (filtered.length === 0) {\r\n                tbody.innerHTML = `\r\n                    <tr>\r\n                        <td colspan=\"4\">\r\n                            <div class=\"empty-state\">\r\n                                <i class=\"fas fa-boxes\"></i>\r\n                                <h5>No Ingredient Categories Found</h5>\r\n                                <p class=\"text-muted\">${searchTerm ? 'Try a different search term' : 'Click \"Add Category\" to create one'}</p>\r\n                            </div>\r\n                        </td>\r\n                    </tr>`;\r\n                return;\r\n            }\r\n\r\n            tbody.innerHTML = filtered.map((cat, index) => `\r\n                <tr>\r\n                    <td class=\"text-muted\">${index + 1}</td>\r\n                    <td><strong>${escapeHtml(cat.name)}</strong></td>\r\n                    <td><span class=\"badge bg-secondary\">${cat.item_count || 0}</span></td>\r\n                    <td>\r\n                        <button class=\"btn btn-action btn-outline-primary me-1\" onclick=\"editIngredientCategory(${cat.id})\" title=\"Edit\">\r\n                            <i class=\"fas fa-edit\"></i>\r\n                        </button>\r\n                        <button class=\"btn btn-action btn-outline-danger\" onclick=\"deleteCategory(${cat.id}, 'ingredient', '${escapeHtml(cat.name)}')\" title=\"Delete\">\r\n                            <i class=\"fas fa-trash\"></i>\r\n                        </button>\r\n                    </td>\r\n                </tr>\r\n            `).join('');\r\n        }\r\n\r\n        function openIngredientCategoryModal(category = null) {\r\n            document.getElementById('ingredientCategoryId').value = category ? category.id : '';\r\n            document.getElementById('ingredientCategoryName').value = category ? category.name : '';\r\n            document.getElementById('ingredientCategoryModalTitle').innerHTML = category \r\n                ? '<i class=\"fas fa-edit me-2\"></i>Edit Ingredient Category' \r\n                : '<i class=\"fas fa-plus me-2\"></i>Add Ingredient Category';\r\n            ingredientCategoryModal.show();\r\n        }\r\n\r\n        function editIngredientCategory(id) {\r\n            const category = ingredientCategories.find(c => c.id === id);\r\n            if (category) openIngredientCategoryModal(category);\r\n        }\r\n\r\n        async function saveIngredientCategory() {\r\n            const id = document.getElementById('ingredientCategoryId').value;\r\n            const name = document.getElementById('ingredientCategoryName').value.trim();\r\n\r\n            if (!name) {\r\n                showModalNotification('Please enter a category name', 'warning');\r\n                return;\r\n            }\r\n\r\n            const btn = document.getElementById('saveIngredientCategoryBtn');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<i class=\"fas fa-spinner fa-spin me-1\"></i>Saving...';\r\n\r\n            try {\r\n                const response = await fetch(`${CATEGORY_API}?action=${id ? 'update' : 'create'}`, {\r\n                    method: 'POST',\r\n                    headers: { 'Content-Type': 'application/json' },\r\n                    body: JSON.stringify({\r\n                        id: id || null,\r\n                        type: 'ingredient',\r\n                        name\r\n                    })\r\n                });\r\n\r\n                const data = await response.json();\r\n\r\n                if (data.success) {\r\n                    showModalNotification(id ? 'Category updated!' : 'Category created!', 'success');\r\n                    ingredientCategoryModal.hide();\r\n                    loadIngredientCategories();\r\n                } else {\r\n                    throw new Error(data.error || 'Failed to save');\r\n                }\r\n            } catch (error) {\r\n                console.error('Error saving ingredient category:', error);\r\n                showModalNotification('Failed to save category', 'error');\r\n            } finally {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '<i class=\"fas fa-save me-1\"></i>Save Category';\r\n            }\r\n        }\r\n\r\n        // =============== DELETE FUNCTIONALITY ===============\r\n\r\n        function deleteCategory(id, type, name) {\r\n            document.getElementById('deleteCategoryId').value = id;\r\n            document.getElementById('deleteCategoryType').value = type;\r\n            document.getElementById('deleteCategoryName').textContent = name;\r\n            deleteCategoryModal.show();\r\n        }\r\n\r\n        async function confirmDelete() {\r\n            const id = document.getElementById('deleteCategoryId').value;\r\n            const type = document.getElementById('deleteCategoryType').value;\r\n\r\n            const btn = document.getElementById('confirmDeleteBtn');\r\n            btn.disabled = true;\r\n            btn.innerHTML = '<i class=\"fas fa-spinner fa-spin me-1\"></i>Deleting...';\r\n\r\n            try {\r\n                const response = await fetch(`${CATEGORY_API}?action=delete`, {\r\n                    method: 'POST',\r\n                    headers: { 'Content-Type': 'application/json' },\r\n                    body: JSON.stringify({ id, type })\r\n                });\r\n\r\n                const data = await response.json();\r\n\r\n                if (data.success) {\r\n                    showModalNotification('Category deleted!', 'success');\r\n                    deleteCategoryModal.hide();\r\n                    if (type === 'menu') {\r\n                        loadMenuCategories();\r\n                    } else {\r\n                        loadIngredientCategories();\r\n                    }\r\n                } else {\r\n                    throw new Error(data.error || 'Failed to delete');\r\n                }\r\n            } catch (error) {\r\n                console.error('Error deleting category:', error);\r\n                showModalNotification('Failed to delete category', 'error');\r\n            } finally {\r\n                btn.disabled = false;\r\n                btn.innerHTML = '<i class=\"fas fa-trash me-1\"></i>Delete';\r\n            }\r\n        }\r\n\r\n        // =============== UTILITIES ===============\r\n\r\n        function escapeHtml(text) {\r\n            if (!text) return '';\r\n            const div = document.createElement('div');\r\n            div.textContent = text;\r\n            return div.innerHTML;\r\n        }\r\n    </script>\r\n</body>\r\n\r\n</html>\r\n"
        }
    ]
