            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Backup & Restore - Admin Dashboard</title>\r\n\r\n    <!-- Bootstrap 5 CSS -->\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <!-- Font Awesome -->\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <!-- Animate.css -->\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css\">\r\n\r\n    <!-- Custom CSS -->\r\n    <link rel=\"stylesheet\" href=\"style.css\">\r\n    <link rel=\"stylesheet\" href=\"admin.css\">\r\n    <script>\r\n        // Immediate Sidebar State Initialization\r\n        (function () {\r\n            const html = document.documentElement;\r\n            html.classList.add('initializing');\r\n\r\n            const sidebarState = localStorage.getItem('sidebarActive');\r\n            if (sidebarState === 'true' && window.innerWidth >= 992) {\r\n                html.classList.add('sidebar-active');\r\n            }\r\n\r\n            // Auth Guard (Admin/Owner version)\r\n            try {\r\n                const role = localStorage.getItem('loggedInRole');\r\n                if (role !== 'admin' && role !== 'owner') {\r\n                    window.location.href = 'index.html';\r\n                }\r\n            } catch (e) {\r\n                window.location.href = 'index.html';\r\n            }\r\n        })();\r\n    </script>\r\n</head>\r\n\r\n<body>\r\n    <!-- Navigation Bar -->\r\n    <nav class=\"navbar navbar-expand-lg navbar-dark bg-black fixed-top shadow\">\r\n        <div class=\"container-fluid\">\r\n            <button class=\"sidebar-toggle mt-1 me-2\" id=\"sidebarToggle\">\r\n                <i class=\"fas fa-bars\"></i>\r\n            </button>\r\n\r\n            <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#headerNav\">\r\n                <span class=\"fas fa-ellipsis-v\"></span>\r\n            </button>\r\n            <div class=\"collapse navbar-collapse\" id=\"headerNav\">\r\n                <ul class=\"navbar-nav ms-auto\">\r\n                    <li class=\"nav-item dropdown\">\r\n                        <a class=\"nav-link dropdown-toggle\" href=\"#\" role=\"button\" data-bs-toggle=\"dropdown\">\r\n                            <i class=\"fas fa-user-shield me-1\"></i>Administrator\r\n                        </a>\r\n                        <ul class=\"dropdown-menu dropdown-menu-end shadow border-0 animate__animated animate__fadeIn\">\r\n                            <li><a class=\"dropdown-item\" href=\"admin-system-settings.html\"><i\r\n                                        class=\"fas fa-cog me-2 text-danger\"></i>Settings</a></li>\r\n                            <li><a class=\"dropdown-item\" href=\"admin-activity-log.html\"><i\r\n                                        class=\"fas fa-history me-2 text-danger\"></i>Activity Log</a></li>\r\n                            <li>\r\n                                <hr class=\"dropdown-divider\">\r\n                            </li>\r\n                            <li><a class=\"dropdown-item text-danger\" href=\"#\" id=\"logoutBtn\"><i\r\n                                        class=\"fas fa-sign-out-alt me-2\"></i>Logout</a></li>\r\n                        </ul>\r\n                    </li>\r\n                </ul>\r\n            </div>\r\n        </div>\r\n    </nav>\r\n\r\n    <div class=\"dashboard-layout\">\r\n        <!-- Sidebar Navigation -->\r\n        <aside class=\"sidebar\" id=\"sidebar\">\r\n            <div class=\"sidebar-branding\">\r\n                <button class=\"sidebar-toggle in-sidebar\" id=\"sidebarToggleInternal\">\r\n                    <i class=\"fas fa-bars\"></i>\r\n                </button>\r\n                <a href=\"admin-dashboard.html\" class=\"sidebar-brand-group\">\r\n                    <img src=\"resources/ethans logo.jpg\" alt=\"Logo\">\r\n                    <span class=\"pos-label\">POS</span>\r\n                </a>\r\n            </div>\r\n            <div class=\"sidebar-nav\">\r\n                <div class=\"sidebar-section-title\">Navigation</div>\r\n                <a href=\"admin-dashboard.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-tachometer-alt\"></i>Dashboard\r\n                </a>\r\n                <a href=\"admin-menu-control.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-utensils\"></i>Menu Control\r\n                </a>\r\n                <a href=\"admin-recipe-control.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-book\"></i>Recipe Control\r\n                </a>\r\n                <a href=\"admin-ingredients-masterlist.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-boxes\"></i>Ingredients\r\n                </a>\r\n                <a href=\"admin-menu_customization.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-palette\"></i>Menu Customization\r\n                </a>\r\n                <a href=\"admin-user-management.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-users\"></i>Users\r\n                </a>\r\n                <a href=\"admin-requests.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-inbox\"></i>Requests\r\n                </a>\r\n\r\n                <div class=\"sidebar-divider\"></div>\r\n                <div class=\"sidebar-section-title\">Reports & Data</div>\r\n                <a href=\"admin-reports.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-chart-bar\"></i>Owner Reports\r\n                </a>\r\n                <a href=\"admin-backup.html\" class=\"sidebar-link active\">\r\n                    <i class=\"fas fa-database\"></i>Backup & Restore\r\n                </a>\r\n\r\n                <div class=\"sidebar-divider\"></div>\r\n                <div class=\"sidebar-section-title\">System</div>\r\n                <a href=\"admin-system-settings.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-cog\"></i>System Settings\r\n                </a>\r\n                <a href=\"admin-activity-log.html\" class=\"sidebar-link\">\r\n                    <i class=\"fas fa-history\"></i>Full Activity Log\r\n                </a>\r\n            </div>\r\n        </aside>\r\n\r\n        <!-- Main Content Area -->\r\n        <main class=\"main-content\">\r\n            <!-- Backup & Restore Content -->\r\n            <div id=\"backup-content\" class=\"page-content\">\r\n                <div\r\n                    class=\"d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom\">\r\n                    <h1 class=\"h2\"><i class=\"fas fa-database me-2 text-danger\"></i>Backup & Restore</h1>\r\n                    <div class=\"btn-toolbar mb-2 mb-md-0\">\r\n                        <button class=\"btn btn-danger\" id=\"createManualBackup\">\r\n                            <i class=\"fas fa-cloud-upload-alt me-1\"></i> Create Manual Backup\r\n                        </button>\r\n                    </div>\r\n                </div>\r\n\r\n                <div class=\"row\">\r\n                    <!-- Backup Settings -->\r\n                    <div class=\"col-lg-5 mb-4\">\r\n                        <div class=\"card shadow h-100\">\r\n                            <div class=\"card-header bg-black text-white\">\r\n                                <h6 class=\"m-0 font-weight-bold\">Backup Configurations</h6>\r\n                            </div>\r\n                            <div class=\"card-body\">\r\n                                <form id=\"backupConfigForm\">\r\n                                    <div class=\"mb-4\">\r\n                                        <label class=\"form-label fw-bold\">Automatic Backup Schedule</label>\r\n                                        <select class=\"form-select\" id=\"autoBackupSchedule\">\r\n                                            <option value=\"Daily\">Daily at Midnight</option>\r\n                                            <option value=\"Weekly\">Weekly (Sundays)</option>\r\n                                            <option value=\"Monthly\">Monthly (1st Day)</option>\r\n                                            <option value=\"Never\">Manual Only</option>\r\n                                        </select>\r\n                                    </div>\r\n                                    <div class=\"mb-4\">\r\n                                        <label class=\"form-label fw-bold\">Backup Retention Policy</label>\r\n                                        <select class=\"form-select\" id=\"backupRetention\">\r\n                                            <option value=\"5\">Keep latest 5 backups</option>\r\n                                            <option value=\"10\">Keep latest 10 backups</option>\r\n                                            <option value=\"30\">Keep latest 30 backups</option>\r\n                                            <option value=\"0\">Keep all backups</option>\r\n                                        </select>\r\n                                    </div>\r\n                                    <div class=\"mb-4\">\r\n                                        <label class=\"form-label fw-bold d-flex align-items-center\">\r\n                                            Backup Format\r\n                                            <i class=\"fas fa-question-circle ms-2 text-muted\" data-bs-toggle=\"tooltip\" data-bs-placement=\"right\" title=\"Choose the format for your backup file\"></i>\r\n                                        </label>\r\n                                        <select class=\"form-select\" id=\"backupFormat\">\r\n                                            <option value=\"json\" data-bs-toggle=\"tooltip\" title=\"Fast & lightweight. Exports data as JSON strings and paths only.\">JSON (Recommended - Fastest)</option>\r\n                                            <option value=\"sql\">SQL (Database dump - paths only, no images)</option>\r\n                                            <option value=\"zip\">ZIP (Complete - includes JSON, SQL & image files)</option>\r\n                                        </select>\r\n                                        <div class=\"mt-2 small\" id=\"formatDescription\">\r\n                                            <div id=\"formatJson\" class=\"text-success\"><i class=\"fas fa-bolt me-1\"></i>Fast export. Data saved as JSON with file paths as strings.</div>\r\n                                            <div id=\"formatSql\" class=\"text-primary d-none\"><i class=\"fas fa-database me-1\"></i>Full database INSERT statements. Images stored as paths only.</div>\r\n                                            <div id=\"formatZip\" class=\"text-warning d-none\"><i class=\"fas fa-file-archive me-1\"></i>Complete backup with JSON + SQL + actual image files. Larger size.</div>\r\n                                        </div>\r\n                                    </div>\r\n                                    <div class=\"mb-4\">\r\n                                        <div class=\"form-check form-switch\">\r\n                                            <input class=\"form-check-input\" type=\"checkbox\" id=\"backupMedia\" checked>\r\n                                            <label class=\"form-check-label\" for=\"backupMedia\">Include Media Assets\r\n                                                (Images)</label>\r\n                                        </div>\r\n                                        <small class=\"text-muted\">Only applies to ZIP format</small>\r\n                                    </div>\r\n                                    <button type=\"button\" class=\"btn btn-outline-danger w-100\" id=\"saveBackupSettings\">\r\n                                        <i class=\"fas fa-save me-1\"></i> Save Configurations\r\n                                    </button>\r\n                                </form>\r\n\r\n                                <hr class=\"my-4\">\r\n\r\n                                <div class=\"p-3 bg-light rounded border\">\r\n                                    <h6 class=\"fw-bold\"><i class=\"fas fa-info-circle me-1 text-danger\"></i>Restore Data\r\n                                    </h6>\r\n                                    <p class=\"small text-muted mb-3\">Restore your system to a previous state using a\r\n                                        valid backup file (.json, .sql, or .zip).</p>\r\n                                    <div class=\"input-group\">\r\n                                        <input type=\"file\" class=\"form-control\" id=\"restoreFile\" accept=\".json,.sql,.zip\">\r\n                                        <button class=\"btn btn-danger\" id=\"runRestoreBtn\">Restore</button>\r\n                                    </div>\r\n                                    <div class=\"alert alert-danger mt-3 mb-0 py-2 small\">\r\n                                        <i class=\"fas fa-exclamation-triangle me-1\"></i> Warning: Current data will be\r\n                                        overwritten.\r\n                                    </div>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <!-- Backup History -->\r\n                    <div class=\"col-lg-7 mb-4\">\r\n                        <div class=\"card shadow h-100\">\r\n                            <div class=\"card-header bg-black text-white\">\r\n                                <h6 class=\"m-0 font-weight-bold\">Backup History Log</h6>\r\n                            </div>\r\n                            <div class=\"card-body\">\r\n                                <div class=\"table-responsive\">\r\n                                    <table class=\"table table-hover align-middle\" id=\"backupHistoryTable\">\r\n                                        <thead>\r\n                                            <tr>\r\n                                                <th>Backup Date</th>\r\n                                                <th>File Name</th>\r\n                                                <th>Size</th>\r\n                                                <th>Type</th>\r\n                                                <th>Actions</th>\r\n                                            </tr>\r\n                                        </thead>\r\n                                        <tbody>\r\n                                            <tr>\r\n                                                <td colspan=\"5\" class=\"text-center\">Loading backup history...</td>\r\n                                            </tr>\r\n                                        </tbody>\r\n                                    </table>\r\n                                </div>\r\n                                <div class=\"mt-3 text-end\">\r\n                                    <button class=\"btn btn-sm btn-secondary\" id=\"pruneBackupsBtn\">\r\n                                        <i class=\"fas fa-trash-alt me-1\"></i> Delete Old Backups\r\n                                    </button>\r\n                                </div>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </main>\r\n    </div>\r\n\r\n    <!-- Bootstrap 5 JS -->\r\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js\"></script>\r\n    <script src=\"https://code.jquery.com/jquery-3.6.4.min.js\"></script>\r\n    <script src=\"https://cdn.jsdelivr.net/npm/sweetalert2@11\"></script>\r\n\r\n    <!-- Custom JS -->\r\n    <script src=\"main.js\"></script>\r\n    <script src=\"admin.js\"></script>\r\n\r\n    <script>\r\n        // Initialize backup page\r\n        document.addEventListener('DOMContentLoaded', function() {\r\n            // Initialize Bootstrap tooltips\r\n            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle=\"tooltip\"]'));\r\n            tooltipTriggerList.map(function (tooltipTriggerEl) {\r\n                return new bootstrap.Tooltip(tooltipTriggerEl);\r\n            });\r\n\r\n            // Backup format change handler\r\n            const formatSelect = document.getElementById('backupFormat');\r\n            const formatJson = document.getElementById('formatJson');\r\n            const formatSql = document.getElementById('formatSql');\r\n            const formatZip = document.getElementById('formatZip');\r\n            const mediaCheckbox = document.getElementById('backupMedia');\r\n\r\n            if (formatSelect) {\r\n                formatSelect.addEventListener('change', function() {\r\n                    // Hide all descriptions\r\n                    formatJson.classList.add('d-none');\r\n                    formatSql.classList.add('d-none');\r\n                    formatZip.classList.add('d-none');\r\n\r\n                    // Show selected format description\r\n                    switch(this.value) {\r\n                        case 'json':\r\n                            formatJson.classList.remove('d-none');\r\n                            mediaCheckbox.disabled = true;\r\n                            mediaCheckbox.checked = false;\r\n                            break;\r\n                        case 'sql':\r\n                            formatSql.classList.remove('d-none');\r\n                            mediaCheckbox.disabled = true;\r\n                            mediaCheckbox.checked = false;\r\n                            break;\r\n                        case 'zip':\r\n                            formatZip.classList.remove('d-none');\r\n                            mediaCheckbox.disabled = false;\r\n                            mediaCheckbox.checked = true;\r\n                            break;\r\n                    }\r\n                });\r\n\r\n                // Trigger initial state\r\n                formatSelect.dispatchEvent(new Event('change'));\r\n            }\r\n\r\n            // Initialize backup functionality from admin.js\r\n            if (typeof initializeBackup === 'function') {\r\n                initializeBackup();\r\n            }\r\n        });\r\n\r\n        // Restore button handler\r\n        document.getElementById('runRestoreBtn').addEventListener('click', function () {\r\n            const file = document.getElementById('restoreFile').files[0];\r\n            if (!file) {\r\n                showModalNotification('Please select a backup file first', 'warning');\r\n                return;\r\n            }\r\n            showConfirm('System will be restored using ' + file.name + '. All current data will be overwritten. Continue?', function () {\r\n                restoreBackup();\r\n            });\r\n        });\r\n    </script>\r\n</body>\r\n\r\n</html>"
        }
    ]
}