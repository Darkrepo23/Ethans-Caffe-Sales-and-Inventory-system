            "date": 1772586090122,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Forgot Password - Ethan's Cafe</title>\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <style>\r\n        body { background: #f8f9fa; }\r\n        .forgot-container { max-width: 400px; margin: 60px auto; background: #fff; border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.12); padding: 32px 28px; }\r\n        .logo { display: block; margin: 0 auto 18px; height: 70px; border-radius: 50%; }\r\n        .form-label { font-weight: 600; }\r\n        .btn-maroon { background: #800000; color: #fff; border: none; }\r\n        .btn-maroon:hover { background: #a64d4d; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"forgot-container\">\r\n        <img src=\"resources/ethans logo.jpg\" alt=\"Logo\" class=\"logo\">\r\n        <h3 class=\"text-center mb-4\">Forgot Password</h3>\r\n        <form id=\"forgotPasswordForm\">\r\n            <div class=\"mb-3\">\r\n                <label for=\"forgotEmail\" class=\"form-label\"><i class=\"fas fa-envelope me-2\"></i>Email address</label>\r\n                <input type=\"email\" class=\"form-control\" id=\"forgotEmail\" name=\"forgotEmail\" placeholder=\"Enter your email\" required>\r\n            </div>\r\n            <div class=\"d-grid mb-3\">\r\n                <button type=\"submit\" class=\"btn btn-maroon\">Send OTP</button>\r\n            </div>\r\n            <div id=\"forgotAlert\" class=\"alert d-none\" role=\"alert\"></div>\r\n        </form>\r\n        <div class=\"text-center mt-3\">\r\n            <a href=\"index.html\" class=\"text-decoration-none\"><i class=\"fas fa-arrow-left me-1\"></i>Back to Login</a>\r\n        </div>\r\n    </div>\r\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js\"></script>\r\n    <script src=\"https://code.jquery.com/jquery-3.6.4.min.js\"></script>\r\n    <script src=\"https://cdn.jsdelivr.net/npm/sweetalert2@11\"></script>\r\n    <script src=\"https://cdn.emailjs.com/dist/email.min.js\"></script>\r\n    <script src=\"forgot-password.js\"></script>\r\n</body>\r\n</html>\r\n"
