            "date": 1772590777896,
            "name": "Commit-0",
            "content": "<!DOCTYPE html>\r\n<html lang=\"en\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Verify OTP - Ethan's Cafe</title>\r\n    <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\r\n    <style>\r\n        body { background: #f8f9fa; }\r\n        .verify-container { max-width: 400px; margin: 60px auto; background: #fff; border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,0.12); padding: 32px 28px; }\r\n        .logo { display: block; margin: 0 auto 18px; height: 70px; border-radius: 50%; }\r\n        .form-label { font-weight: 600; }\r\n        .btn-maroon { background: #800000; color: #fff; border: none; }\r\n        .btn-maroon:hover { background: #a64d4d; }\r\n    </style>\r\n</head>\r\n<body>\r\n    <div class=\"verify-container\">\r\n        <img src=\"resources/ethans logo.jpg\" alt=\"Logo\" class=\"logo\">\r\n        <h3 class=\"text-center mb-4\">Verify OTP</h3>\r\n        <form id=\"verifyOtpForm\">\r\n            <div class=\"mb-3\">\r\n                <label for=\"otpCode\" class=\"form-label\"><i class=\"fas fa-key me-2\"></i>Enter OTP Code</label>\r\n                <input type=\"text\" class=\"form-control\" id=\"otpCode\" name=\"otpCode\" placeholder=\"Enter the OTP\" required maxlength=\"6\">\r\n            </div>\r\n            <div class=\"d-grid mb-3\">\r\n                <button type=\"submit\" class=\"btn btn-maroon\">Verify</button>\r\n            </div>\r\n            <div id=\"verifyAlert\" class=\"alert d-none\" role=\"alert\"></div>\r\n        </form>\r\n        <div id=\"changePasswordSection\" style=\"display:none;\">\r\n            <form id=\"changePasswordForm\">\r\n                <div class=\"mb-3\">\r\n                    <label for=\"newPassword\" class=\"form-label\"><i class=\"fas fa-lock me-2\"></i>New Password</label>\r\n                    <input type=\"password\" class=\"form-control\" id=\"newPassword\" name=\"newPassword\" placeholder=\"Enter new password\" required minlength=\"6\">\r\n                </div>\r\n                <div class=\"mb-3\">\r\n                    <label for=\"confirmPassword\" class=\"form-label\"><i class=\"fas fa-lock me-2\"></i>Confirm Password</label>\r\n                    <input type=\"password\" class=\"form-control\" id=\"confirmPassword\" name=\"confirmPassword\" placeholder=\"Confirm new password\" required minlength=\"6\">\r\n                </div>\r\n                <div class=\"d-grid mb-3\">\r\n                    <button type=\"submit\" class=\"btn btn-maroon\">Change Password</button>\r\n                </div>\r\n                <div id=\"changePasswordAlert\" class=\"alert d-none\" role=\"alert\"></div>\r\n            </form>\r\n        </div>\r\n        <div class=\"text-center mt-3\">\r\n            <a href=\"forgot-password.html\" class=\"text-decoration-none\"><i class=\"fas fa-arrow-left me-1\"></i>Back to Forgot Password</a>\r\n        </div>\r\n    </div>\r\n    <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js\"></script>\r\n    <script src=\"https://code.jquery.com/jquery-3.6.4.min.js\"></script>\r\n    <script src=\"https://cdn.jsdelivr.net/npm/sweetalert2@11\"></script>\r\n    <script src=\"verify-otp.js\"></script>\r\n</body>\r\n</html>\r\n"
